# Build artefacts — amc-generated .c files (anything in build dirs
# or at project roots) ignored, but NOT the hand-written supervisor
# C source under tools/.
/*.c
**/build/**/*.c
*.o
*.a
server
*.log

# Compiled supervisor binary (built via `cc tools/mosaic-supervise.c`)
tools/mosaic-supervise

# Generated by mosaic-routes.sh
**/_routes.am

# Lockfiles are usually committed by users, but skip in the demo
# since tests/run_tests.sh regenerates them from the local cache.
examples/*/amalgame.lock
